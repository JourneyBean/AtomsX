# AtomsX Environment Variables
# Copy this to .env and fill in the values
#
# IMPORTANT: When running in Docker Compose, use Docker service names (e.g., 'postgres', 'redis', 'backend')
# instead of 'localhost' or '127.0.0.1'. localhost in a container refers to the container itself, not the host.
# Service names like 'postgres', 'redis', 'backend' resolve correctly within the Docker network.

# =============================================================================
# DJANGO CONFIGURATION
# =============================================================================
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,.preview.local,.apps.local

# =============================================================================
# POSTGRESQL CONFIGURATION (Shared by all services)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=atomsx
POSTGRES_USER=atomsx
POSTGRES_PASSWORD=atomsx_password

# =============================================================================
# REDIS CONFIGURATION (Shared by all services)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=  # Uncomment if Redis requires authentication

# =============================================================================
# OIDC CONFIGURATION (Authentik)
# =============================================================================
OIDC_PROVIDER_URL=http://authentik-server:9000/application/o/atomsx/
OIDC_CLIENT_ID=atomsx
OIDC_CLIENT_SECRET=change-me
# Redirect URI: Use Gateway path for browser access (not service name)
# The browser accesses this URL, not the container, so use the host-accessible URL
OIDC_REDIRECT_URI=http://localhost/api/auth/callback

# =============================================================================
# AUTHENTIK CONFIGURATION (Development Only)
# Authentik is included in docker-compose.dev.yml with dedicated PostgreSQL.
# Data is persisted in .dev-cache/ directory (separate from main app volumes).
# Production should use external OIDC provider (e.g., Auth0, Okta, enterprise SSO).
# =============================================================================
AUTHENTIK_SECRET_KEY=change-me-to-at-least-50-characters-long
AUTHENTIK_POSTGRESQL_NAME=atomsx_authentik
# Bootstrap configuration (only read on first startup)
AUTHENTIK_BOOTSTRAP_PASSWORD=akadmin
AUTHENTIK_BOOTSTRAP_TOKEN=your-bootstrap-token
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com

# =============================================================================
# CORS CONFIGURATION
# Note: These are browser-accessible origins, so localhost is appropriate for local development
# In production, use actual domain (e.g., https://app.example.com)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# WORKSPACE / DOCKER CONFIGURATION
# =============================================================================
# Development: Use host Docker socket (set in docker-compose.dev.yml)
# Production: Use Docker-in-Docker for isolation

# Workspace settings
WORKSPACE_NETWORK_NAME=atomsx-workspaces
WORKSPACE_BASE_IMAGE=atomsx-workspace:latest

# Domain configuration for user workspace apps
# These domains are used for workspace preview and deployed app URLs.
# Note: These domains are NOT trusted for CORS/CSRF - user apps are isolated.

# ATOMSX_PREVIEW_DOMAIN: Domain for workspace preview URLs (development/debugging)
# Format: {workspace-id}.{ATOMSX_PREVIEW_DOMAIN}
# IMPORTANT: Do NOT include port number! nginx server_name matches HTTP Host header,
# which excludes port for standard ports. The gateway port mapping is handled separately.
# Examples: preview.local, preview.localhost, preview.example.com
ATOMSX_PREVIEW_DOMAIN=preview.local

# ATOMSX_DEPLOY_DOMAIN: Domain for workspace deployed app URLs (production)
# Format: {workspace-id}.{ATOMSX_DEPLOY_DOMAIN}
# IMPORTANT: Do NOT include port number!
# Examples: apps.local, apps.localhost, apps.example.com
ATOMSX_DEPLOY_DOMAIN=apps.local

# Workspace data storage root path
# Default: /var/opt/atomsx/workspaces
# Directory structure: {root}/{uuid[0]}/{uuid[1]}/{uuid}/
#   - workspace/ : User code repository
#   - history/   : Conversation history
#ATOMSX_WORKSPACE_DATA_ROOT=/var/opt/atomsx/workspaces

# Docker-in-Docker settings (production only)
DIND_ENABLED=true
DIND_SOCKET_PATH=/var/run/dind/docker.sock
DOCKER_HOST=unix:///var/run/dind/docker.sock

# =============================================================================
# OPTIONAL: CLAUDE API KEY
# =============================================================================
# ANTHROPIC_API_KEY=your-claude-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional: custom API endpoint
# ANTHROPIC_MODEL=claude-sonnet-4-6  # Optional: model to use (e.g., claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5)

# =============================================================================
# WORKSPACE CLIENT CONFIGURATION
# =============================================================================
# WebSocket URL for Workspace Client to connect to Backend
# Development: Use Docker service name
# Production: Use internal URL or load balancer
WORKSPACE_CLIENT_WS_URL=ws://backend:8000
WORKSPACE_CLIENT_HTTP_URL=http://backend:8000

# Internal API token for service-to-service communication
# Used by Workspace Client to authenticate when fetching agent config
# Generate a secure random token for production
ATOMSX_INTERNAL_API_TOKEN=dev-internal-token-change-in-production

# =============================================================================
# OPTIONAL: PROXY CONFIGURATION
# =============================================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.internal.example.com